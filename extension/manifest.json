{
  "manifest_version": 3,
  "name": "Voicey",
  "version": "0.6.2",
  "description": "Reads webpages aloud in your own cloned voice, with live highlighting — fully local.",
  "permissions": ["activeTab", "scripting", "storage", "contextMenus", "tabs", "tabCapture", "offscreen"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Read this page aloud with Voicey (Alt+V)"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+V",
        "mac": "Alt+V"
      },
      "description": "Toggle Voicey on the current page"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
